# Optional repo config (copy to .github/robin.yml)
# Read from the PR base branch. Action inputs override these when explicitly set.

max-diff-size: 25000
max-comments: 10
json-response-mode: true
# request-changes: true   # default; set false for advisor mode (never block the PR, even on high findings)

skip-paths:
  - "**/generated/**"
  - "**/*.snap"
